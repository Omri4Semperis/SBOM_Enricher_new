{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "python scripts/ai_docs_parity.py --emit cursor --block"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python .cursor/skills/git-hygiene/scripts/git_hygiene_scan.py --hook",
        "matcher": "\\bgit\\b.*\\bcommit\\b"
      }
    ],
    "preCompact": [
      {
        "command": "python .cursor/skills/handoff/scripts/precompact_backup.py"
      }
    ]
  }
}
